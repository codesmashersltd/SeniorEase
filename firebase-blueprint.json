{
  "entities": {
    "Ticket": {
      "title": "Ticket",
      "description": "Represents a support ticket or query from the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "enquiryType": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "In Progress", "Resolved", "Closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "phone", "enquiryType", "message", "status", "createdAt"]
    }
  },
  "firestore": {
    "/tickets/{ticketId}": {
      "schema": { "$ref": "#/entities/Ticket" },
      "description": "Stores user inquiries and support tickets."
    }
  }
}

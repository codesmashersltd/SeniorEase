rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { allow read, write: if false; }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'yashkumars@gmail.com' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128; }

    // 1. Tickets Validation
    function isValidTicket(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 500
        && data.email is string && data.email.size() < 500
        && (data.phone is string || data.phone == null)
        && (data.enquiryType is string || data.enquiryType == null)
        && (data.message is string || data.message == null)
        && data.status in ['Open', 'Pending', 'In Progress', 'Resolved', 'Closed']
        && (data.source is string || data.source == null)
        && data.createdAt == request.time;
    }

    match /tickets/{ticketId} {
      allow create: if isValidTicket(incoming());
      allow read, update, delete: if isAdmin();
    }

    // 2. New Joinees Validation
    function isValidJoinee(data) {
      return data.customerId is string && data.customerId.size() > 0
        && data.name is string && data.name.size() > 0
        && data.email is string && data.email.size() > 0
        && data.plan is string
        && data.createdAt == request.time;
    }

    match /new_joinees/{joineeId} {
      allow create: if isValidJoinee(incoming());
      allow read, update, delete: if isAdmin();
    }

    // 3. Customers
    match /customers/{customerId} {
      allow read: if true; // Public access for identity verification in login
      allow create: if isAdmin() || true; // Public can register via JoinModal if it used customers, but it uses new_joinees now
      allow update, delete: if isAdmin();
    }

    // 4. Others
    match /loginLogs/{logId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admin_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /renewals/{renewalId} {
      allow read, write, delete: if isAdmin();
    }
  }
}
